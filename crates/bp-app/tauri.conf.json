{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BoxPassword",
  "version": "0.1.0",
  "identifier": "com.boxpassword.app",
  "build": {
    "frontendDist": "../../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BoxPassword",
        "width": 1100,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      },
      {
        "label": "quick",
        "url": "quick.html",
        "title": "BoxPassword 빠른 검색",
        "width": 520,
        "height": 360,
        "visible": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Productivity",
    "shortDescription": "개인용 패스워드 관리 데스크톱 앱",
    "longDescription": "Argon2id + AES-256-GCM으로 봉인된 로컬 vault, 변경 이력, 백업/복구, TOTP, CSV 가져오기까지 갖춘 패스워드 매니저.",
    "copyright": "© BoxPassword contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "wix": {
        "language": ["en-US", "ko-KR"]
      }
    }
  }
}
